# PostgreSQL connection string for RDS (token storage)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_RDS_ENDPOINT:5432/postgres?sslmode=require

# OAuth callback URL — must match Google Cloud Console redirect URI exactly
REDIRECT_URI=http://YOUR_EC2_PUBLIC_IP.nip.io/auth/callback

# Random secret used to sign Flask session cookies
FLASK_SECRET=replace_with_a_random_string
