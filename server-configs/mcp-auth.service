[Unit]
Description=Google Workspace Auth Server
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/workspace_mcp
Environment=PYTHONPATH=/home/ubuntu/workspace_mcp
EnvironmentFile=/home/ubuntu/workspace_mcp/.env
ExecStart=/home/ubuntu/workspace_mcp/venv/bin/python /home/ubuntu/workspace_mcp/auth/auth_server.py
Restart=always

[Install]
WantedBy=multi-user.target
